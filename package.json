{
  "name": "dustoff",
  "version": "0.1.0",
  "description": "Find and remove JS/TS build artifacts wasting disk space",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "memfs": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
