{
  "name": "dustoff",
  "version": "0.1.0",
  "description": "Find and remove JS/TS build artifacts wasting disk space",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dustoff": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test src/features/",
    "test:integration": "bun test test/integration/",
    "build": "bun build src/cli.tsx --outfile dist/cli.js --target node --packages external",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "memfs": "^4.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "pretty-bytes": "^6.1.1",
    "react": "^19.2.4"
  }
}
