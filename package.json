{
  "name": "dustoff",
  "version": "0.1.0",
  "description": "Find and remove JS/TS build artifacts wasting disk space",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dustoff": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run test/unit/",
    "test:integration": "vitest run test/integration/",
    "test:watch": "vitest",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "memfs": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "pretty-bytes": "^6.1.1",
    "react": "^19.2.4"
  }
}
